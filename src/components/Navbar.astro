---
import processPosts from "../data/process.json";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { to: "/", label: "Works" },
  ...(processPosts.length > 0 ? [{ to: "/process", label: "Process" }] : []),
  { to: "/about", label: "About" },
  { to: "/contact", label: "Contact" },
];
---

<div
  style={{
    position: "fixed",
    top: 0,
    left: 0,
    right: 0,
    height: "64px",
    background:
      "linear-gradient( 90deg, rgb(255 255 240) 0%, rgb(246 254 255) 100% )",
    display: "flex",
    justifyContent: "flex-start",
    zIndex: 101,
  }}
>
  <div
    style={{
      width: "100%",
      display: "flex",
      alignItems: "center",
      justifyContent: "flex-start",
      gap: "32px",
      padding: "0px 32px",
    }}
    class="mobilePaddingSmall"
  >
    <a
      style={{
        textDecoration: "none",
        fontWeight: 600,
        fontSize: "16px",
        whiteSpace: "nowrap",
        lineHeight: "100%",
        color: "#999",
      }}
      href="/"
    >
      Sam
      <br />
      Ticknor
    </a>
    <div
      style={{
        width: "100%",
        display: "flex",
        alignItems: "center",
        justifyContent: "flex-start",
        gap: "32px",
      }}
      class="mobileGap"
    >
      {
        links.map((link) => (
          <a
            class={pathname === link.to ? "" : "clickable"}
            style={{
              textDecoration: pathname === link.to ? "underline" : "none",
              color: "black",
              fontWeight: 600,
            }}
            href={link.to}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</div>
