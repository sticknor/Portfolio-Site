---
import Layout from "../layouts/Layout.astro";
import WorksLightbox from "../components/WorksLightbox.jsx";
import ModuleRenderer from "../components/ModuleRenderer.jsx";
import about from "../data/about.json";
import works from "../data/works.json";
import collections from "../data/collections.json";
import dateCollections from "../data/dateCollections.json";
import installations from "../data/installations.json";

export async function getStaticPaths() {
  const worksData = works;
  const resolveWorks = (ids) => ids.map((id) => worksData[id]).filter(Boolean);

  const paths = [];
  const seen = new Set();
  const add = (slug, props) => {
    if (!slug || seen.has(slug)) return;
    seen.add(slug);
    paths.push({ params: { slug }, props });
  };

  for (const collection of collections) {
    add(collection.route, {
      type: "collection",
      collection,
      pageWorks: resolveWorks(collection.workIds),
    });
  }

  // Old per-year URLs (/2024 etc.) now redirect to /archive#2024
  for (const date of Object.keys(dateCollections)) {
    add(date, { type: "date", date });
  }

  for (const installation of installations) {
    add(installation.route, {
      type: "installation",
      installation,
      modules: installation.modules.map((m) => ({
        ...m,
        moduleWorks: resolveWorks(m.workIds),
      })),
    });
  }

  return paths;
}

const { type, collection, date, pageWorks, installation, modules } =
  Astro.props;

const archiveUrl = type === "date" ? `/archive#${encodeURIComponent(date)}` : null;

const pageTitle =
  type === "collection"
    ? `${collection.title} — ${about.siteTitle}`
    : type === "date"
      ? `${date} — ${about.siteTitle}`
      : `${installation.title} — ${about.siteTitle}`;

const ogImage =
  type === "installation"
    ? installation.image?.src
    : pageWorks?.find((w) => w.image)?.image?.src;
---

{
  type === "date" ? (
    <html lang="en">
      <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{pageTitle}</title>
        <link rel="canonical" href={new URL("/archive", Astro.site)} />
        <meta http-equiv="refresh" content={`0; url=${archiveUrl}`} />
        <script is:inline define:vars={{ archiveUrl }}>
          window.location.replace(archiveUrl);
        </script>
      </head>
      <body>
        <a href={archiveUrl}>Redirecting to the Archive…</a>
      </body>
    </html>
  ) : (
    <Layout title={pageTitle} ogImage={ogImage}>
      {type === "collection" && (
        <div style={{ marginTop: "64px", backgroundColor: "#fff" }}>
          <div
            style={{
              display: "flex",
              flexDirection: "row",
              padding: "64px",
              flex: 1,
              gap: "64px",
            }}
            class="mobileStack mobilePadding mobileGap"
          >
            <div
              style={{
                flex: 1,
                display: "flex",
                justifyContent: "space-between",
                alignItems: "space-between",
                flexDirection: "column",
              }}
            >
              <div>
                <div style={{ fontWeight: 600, marginBottom: "8px" }}>
                  {collection.title}
                  {collection.years && (
                    <div style={{ opacity: 0.6, fontWeight: 500 }}>
                      {" — "}
                      {collection.years}
                    </div>
                  )}
                </div>
                {collection.collectionStatement && (
                  <div
                    style={{
                      paddingTop: "24px",
                      paddingBottom: "0px",
                      whiteSpace: "pre-wrap",
                    }}
                  >
                    {collection.collectionStatement}
                  </div>
                )}
              </div>
            </div>
            <div
              class="pageCollectionsContent"
              style={{
                height: "100%",
                flex: 2,
                display: "flex",
                overflow: "auto",
                WebkitOverflowScrolling: "touch",
              }}
            >
              <WorksLightbox client:load works={pageWorks} />
            </div>
          </div>
        </div>
      )}

      {type === "installation" && (
        <div
          id="scrollContent"
          class="mobilePadding"
          style={{
            width: "100%",
            marginTop: "64px",
            paddingTop: "64px",
            paddingLeft: "64px",
            paddingRight: "64px",
            backgroundColor: "#fff",
            boxSizing: "border-box",
          }}
        >
          <ModuleRenderer modules={modules} />
        </div>
      )}
    </Layout>
  )
}
