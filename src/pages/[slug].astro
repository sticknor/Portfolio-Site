---
import Layout from "../layouts/Layout.astro";
import WorksLightbox from "../components/WorksLightbox.jsx";
import ModuleRenderer from "../components/ModuleRenderer.jsx";
import about from "../data/about.json";
import works from "../data/works.json";
import collections from "../data/collections.json";
import dateCollections from "../data/dateCollections.json";
import installations from "../data/installations.json";

export async function getStaticPaths() {
  const worksData = works;
  const resolveWorks = (ids) => ids.map((id) => worksData[id]).filter(Boolean);

  const paths = [];
  const seen = new Set();
  const add = (slug, props) => {
    if (!slug || seen.has(slug)) return;
    seen.add(slug);
    paths.push({ params: { slug }, props });
  };

  for (const collection of collections) {
    add(collection.route, {
      type: "collection",
      collection,
      pageWorks: resolveWorks(collection.workIds),
    });
  }

  const sortedDates = Object.keys(dateCollections).sort();
  for (const date of sortedDates) {
    add(date, {
      type: "date",
      date,
      dates: sortedDates,
      pageWorks: resolveWorks(dateCollections[date]),
    });
  }

  for (const installation of installations) {
    add(installation.route, {
      type: "installation",
      installation,
      modules: installation.modules.map((m) => ({
        ...m,
        moduleWorks: resolveWorks(m.workIds),
      })),
    });
  }

  return paths;
}

const { type, collection, date, dates, pageWorks, installation, modules } =
  Astro.props;

const pageTitle =
  type === "collection"
    ? `${collection.title} — ${about.siteTitle}`
    : type === "date"
      ? `${date} — ${about.siteTitle}`
      : `${installation.title} — ${about.siteTitle}`;

const ogImage =
  type === "installation"
    ? installation.image?.src
    : pageWorks?.find((w) => w.image)?.image?.src;
---

<Layout title={pageTitle} ogImage={ogImage}>
  {
    type === "collection" && (
      <div style={{ marginTop: "64px", backgroundColor: "#fff" }}>
        <div
          style={{
            display: "flex",
            flexDirection: "row",
            padding: "64px",
            flex: 1,
            gap: "64px",
          }}
          class="mobileStack mobilePadding mobileGap"
        >
          <div
            style={{
              flex: 1,
              display: "flex",
              justifyContent: "space-between",
              alignItems: "space-between",
              flexDirection: "column",
            }}
          >
            <div>
              <div style={{ fontWeight: 600, marginBottom: "8px" }}>
                {collection.title}
                {collection.years && (
                  <div style={{ opacity: 0.6, fontWeight: 500 }}>
                    {" — "}
                    {collection.years}
                  </div>
                )}
              </div>
              {collection.collectionStatement && (
                <div
                  style={{
                    paddingTop: "24px",
                    paddingBottom: "0px",
                    whiteSpace: "pre-wrap",
                  }}
                >
                  {collection.collectionStatement}
                </div>
              )}
            </div>
          </div>
          <div
            style={{
              height: "100%",
              flex: 2,
              display: "flex",
              overflow: "auto",
              WebkitOverflowScrolling: "touch",
            }}
          >
            <WorksLightbox client:load works={pageWorks} />
          </div>
        </div>
      </div>
    )
  }

  {
    type === "date" && (
      <div
        style={{
          marginTop: "64px",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          flex: 1,
          backgroundColor: "#fff",
        }}
      >
        <div
          style={{
            display: "flex",
            flexDirection: "column",
            alignItems: "center",
            justifyContent: "center",
            padding: "64px",
            flex: 1,
            gap: "64px",
          }}
          class="mobileStack mobilePadding mobileGap"
        >
          <div
            style={{
              display: "flex",
              flexDirection: "row",
              alignItems: "center",
              justifyContent: "center",
              flex: 1,
              gap: "64px",
            }}
            class="mobileStack mobilePadding mobileGap"
          >
            {dates.map((dateCollectionID) => (
              <a
                href={`/${encodeURIComponent(dateCollectionID)}`}
                style={{
                  color: "black",
                  fontWeight: dateCollectionID === date ? 600 : 400,
                  textDecoration:
                    dateCollectionID === date ? "underline" : "none",
                }}
                class={dateCollectionID === date ? "" : "clickable"}
              >
                {dateCollectionID}
              </a>
            ))}
          </div>
          <WorksLightbox client:load works={pageWorks} centered />
        </div>
      </div>
    )
  }

  {
    type === "installation" && (
      <div
        id="scrollContent"
        class="mobilePadding"
        style={{
          width: "100%",
          marginTop: "64px",
          paddingTop: "64px",
          paddingLeft: "64px",
          paddingRight: "64px",
          backgroundColor: "#fff",
          boxSizing: "border-box",
        }}
      >
        <ModuleRenderer modules={modules} />
      </div>
    )
  }
</Layout>
