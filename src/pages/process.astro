---
import Layout from "../layouts/Layout.astro";
import about from "../data/about.json";
import posts from "../data/process.json";
---

<Layout title={`Process — ${about.siteTitle}`}>
  <div style={{ marginTop: "64px", minHeight: "100vh" }}>
    <div
      style={{ display: "flex", flexDirection: "column", padding: "64px" }}
      class="mobilePadding"
    >
      {
        posts.map((post) => (
          <div
            style={{
              display: "flex",
              flexDirection: "column",
              gap: "64px",
            }}
          >
            <div
              style={{
                display: "flex",
                flexDirection: "row",
                gap: "64px",
              }}
            >
              <div style={{ opacity: 0.5, marginBottom: "16px" }}>
                {post.date}
              </div>
              <div style={{ fontWeight: 600 }}>{post.title}</div>
            </div>
            <div>
              {post.images.map((image) => (
                <img
                  width="300"
                  style={{ height: "auto" }}
                  src={image.src}
                  srcset={image.srcSet}
                  sizes="300px"
                  loading="lazy"
                  decoding="async"
                  alt={post.title || "process image"}
                />
              ))}
              <div>{post.text}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
