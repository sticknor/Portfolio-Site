---
import Layout from "../layouts/Layout.astro";
import MenuTile from "../components/MenuTile.astro";
import SplashCarousel from "../components/SplashCarousel.jsx";
import { WorkInfoLine } from "../components/formatWorkDetails.jsx";
import about from "../data/about.json";
import collections from "../data/collections.json";
import dates from "../data/dates.json";
import installations from "../data/installations.json";

const menuCollections = collections.filter((c) => c.showInMenu);
const menuInstallations = installations.filter((i) => i.showInMenu);
const splashWorks = about.splashWorks ?? [];
const firstSplash = splashWorks[0]?.image;

// A 1x1 transparent gif, used in <picture> sources so each viewport only
// downloads the splash treatment it actually shows.
const BLANK_GIF =
  "data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==";
---

<Layout title={about.siteTitle} ogImage={firstSplash?.src}>
  {
    firstSplash && (
      <link
        slot="head"
        rel="preload"
        as="image"
        imagesrcset={firstSplash.srcSet}
        imagesizes="55vw"
        fetchpriority="high"
        media="(min-width: 861px)"
      />
    )
  }
  <div>
    {
      splashWorks.length > 0 && (
        <div class="homeSplashPane mobileHide">
          <SplashCarousel
            client:media="(min-width: 861px)"
            works={splashWorks}
          />
        </div>
      )
    }

    <!-- Menus on Left (desktop) / collapsible menu + stacked highlights (mobile) -->
    <div class="homeContent mobileFullWidth">
      <div
        class="mobilePadding"
        style={{
          marginTop: "64px",
          gap: "64px",
          padding: "64px",
          paddingTop: "32px",
          display: "flex",
          flex: 1,
          flexDirection: "column",
        }}
      >
        <!-- Mobile-only menu disclosure (CSS checkbox toggle, no JS) -->
        <input type="checkbox" id="homeMenuToggle" class="homeMenuCheckbox" />
        <label for="homeMenuToggle" class="homeMenuButton clickable">
          <span class="homeMenuButtonLabel-open">Menu +</span>
          <span class="homeMenuButtonLabel-close">Menu −</span>
        </label>

        <div class="homeMenuSections">
          <!-- Series -->
          <div>
            <span class="homeMenuHeading">Series:</span>
            <div class="homeTileRow">
              {
                menuCollections.map((collection) => (
                  <MenuTile
                    href={`/${encodeURIComponent(collection.route)}`}
                    image={collection.image}
                    label={collection.title}
                    lines={[collection.years]}
                  />
                ))
              }
            </div>
          </div>

          <!-- Installations -->
          <div>
            <span class="homeMenuHeading">Installations:</span>
            <div class="homeTileRow">
              {
                menuInstallations.map((installation) => (
                  <MenuTile
                    href={`/${encodeURIComponent(installation.route)}`}
                    image={installation.image}
                    label={installation.title}
                    lines={[installation.location, installation.dates]}
                  />
                ))
              }
            </div>
          </div>

          <!-- Archive -->
          <div>
            <span class="homeMenuHeading">Archive:</span>
            <div class="homeTileRow">
              {
                dates.map((entry) => (
                  <MenuTile
                    href={`/archive#${encodeURIComponent(entry.date)}`}
                    image={entry.image}
                    label={entry.date}
                  />
                ))
              }
            </div>
          </div>
        </div>

        <!-- Mobile: highlights as a quick-scroll vertical stack -->
        {
          splashWorks.length > 0 && (
            <div class="homeMobileHighlights">
              {splashWorks.map((work, i) => (
                <div>
                  <picture>
                    {/* Desktop never downloads these (carousel shows them instead) */}
                    <source media="(min-width: 861px)" srcset={BLANK_GIF} />
                    <source
                      media="(max-width: 860px)"
                      srcset={work.image.srcSet}
                      sizes="100vw"
                    />
                    <img
                      alt={
                        work.title ||
                        `Highlighted artwork ${i + 1} by Sam Ticknor`
                      }
                      src={work.image.src}
                      width={work.image.width}
                      height={work.image.height}
                      loading={i === 0 ? "eager" : "lazy"}
                      fetchpriority={i === 0 ? "high" : "auto"}
                      decoding="async"
                      style={{
                        width: "100%",
                        height: "auto",
                        display: "block",
                      }}
                    />
                  </picture>
                  <div
                    style={{
                      marginTop: "12px",
                      fontSize: "14px",
                      lineHeight: 1.5,
                    }}
                  >
                    <WorkInfoLine work={work} />
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</Layout>
